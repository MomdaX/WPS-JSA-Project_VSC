      "examples": "<div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*下例中“自动更正选项”按钮将出现在单元格 A1 旁，该单元格包含用两位数字表示年份的文本日期。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-comment\">//Simulate an error by referencing a text date with a two-digit year.</span>\n    <span class=\"hljs-title class_\">Application</span>.<span class=\"hljs-property\">ErrorCheckingOptions</span>.<span class=\"hljs-property\">TextDate</span> = <span class=\"hljs-literal\">true</span>\n    <span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;A1&quot;</span>).<span class=\"hljs-property\">Formula</span> = <span class=\"hljs-string\">&quot;&#x27;00/4/23&quot;</span>\n}</code></pre></td></tr></tbody></table></div><div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*本示例显示 ErrorCheckingOptions 对象的 TextDate 属性值。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-title function_\">alert</span>(<span class=\"hljs-title class_\">Application</span>.<span class=\"hljs-property\">ErrorCheckingOptions</span>.<span class=\"hljs-property\">TextDate</span>)\n}</code></pre></td></tr></tbody></table></div>",
