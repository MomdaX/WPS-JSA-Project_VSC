{
  "name": "Sort",
  "summary": "<p><b class=\"mainheaders\">示例</b></p><div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*此示例为活动工作表区域A1:A11赋值，并对这些数据排序。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-comment\">//Building data to sort on the active sheet.</span>\n    <span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;A1&quot;</span>).<span class=\"hljs-property\">Value2</span> = <span class=\"hljs-string\">&quot;Name&quot;</span>\n    <span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;A2&quot;</span>).<span class=\"hljs-property\">Value2</span> = <span class=\"hljs-string\">&quot;Bill&quot;</span>\n    <span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;A3&quot;</span>).<span class=\"hljs-property\">Value2</span> = <span class=\"hljs-string\">&quot;Rod&quot;</span>\n    <span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;A4&quot;</span>).<span class=\"hljs-property\">Value2</span> = <span class=\"hljs-string\">&quot;John&quot;</span>\n    <span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;A5&quot;</span>).<span class=\"hljs-property\">Value2</span> = <span class=\"hljs-string\">&quot;Paddy&quot;</span>\n    <span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;A6&quot;</span>).<span class=\"hljs-property\">Value2</span> = <span class=\"hljs-string\">&quot;Kelly&quot;</span>\n    <span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;A7&quot;</span>).<span class=\"hljs-property\">Value2</span> = <span class=\"hljs-string\">&quot;William&quot;</span>\n    <span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;A8&quot;</span>).<span class=\"hljs-property\">Value2</span> = <span class=\"hljs-string\">&quot;Janet&quot;</span>\n    <span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;A9&quot;</span>).<span class=\"hljs-property\">Value2</span> = <span class=\"hljs-string\">&quot;Florence&quot;</span>\n    <span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;A10&quot;</span>).<span class=\"hljs-property\">Value2</span> = <span class=\"hljs-string\">&quot;Albert&quot;</span>\n    <span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;A11&quot;</span>).<span class=\"hljs-property\">Value2</span> = <span class=\"hljs-string\">&quot;Mary&quot;</span>\n    <span class=\"hljs-title function_\">alert</span>(<span class=\"hljs-string\">&quot;The list is out of order.  Hit Ok to continue...&quot;</span>)\n\n    <span class=\"hljs-comment\">//Selecting a cell within the range.</span>\n    <span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;A2&quot;</span>).<span class=\"hljs-title class_\">Select</span>()\n\n    <span class=\"hljs-comment\">//Applying sort.</span>\n    <span class=\"hljs-keyword\">let</span> sort = <span class=\"hljs-title class_\">Application</span>.<span class=\"hljs-property\">ActiveWorkbook</span>.<span class=\"hljs-property\">Worksheets</span>.<span class=\"hljs-title class_\">Item</span>(<span class=\"hljs-title class_\">ActiveSheet</span>.<span class=\"hljs-property\">Name</span>).<span class=\"hljs-property\">Sort</span>\n    sort.<span class=\"hljs-property\">SortFields</span>.<span class=\"hljs-title class_\">Clear</span>()\n    sort.<span class=\"hljs-property\">SortFields</span>.<span class=\"hljs-title class_\">Add</span>(<span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;A2:A11&quot;</span>), xlSortOnValues, xlAscending, xlSortNormal)\n    sort.<span class=\"hljs-title class_\">SetRange</span>(<span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;A1:A11&quot;</span>))\n    sort.<span class=\"hljs-property\">Header</span> = xlYes\n    sort.<span class=\"hljs-property\">MatchCase</span> = <span class=\"hljs-literal\">false</span>\n    sort.<span class=\"hljs-property\">Orientation</span> = xlTopToBottom\n    sort.<span class=\"hljs-property\">SortMethod</span> = xlPinYin\n    sort.<span class=\"hljs-title class_\">Apply</span>()\n    <span class=\"hljs-title function_\">alert</span>(<span class=\"hljs-string\">&quot;Sort complete.&quot;</span>)\n}</code></pre></td></tr></tbody></table></div><div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*此示例对第一张工作表区域A1:C1按字符的汉语拼音顺序排序。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-keyword\">let</span> sort = <span class=\"hljs-title class_\">Application</span>.<span class=\"hljs-property\">Sheets</span>.<span class=\"hljs-title class_\">Item</span>(<span class=\"hljs-number\">1</span>).<span class=\"hljs-property\">Sort</span>\n    sort.<span class=\"hljs-property\">SortFields</span>.<span class=\"hljs-title class_\">Clear</span>()\n    sort.<span class=\"hljs-property\">SortFields</span>.<span class=\"hljs-title class_\">Add</span>(<span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;A1:C1&quot;</span>))\n    sort.<span class=\"hljs-title class_\">SetRange</span>(<span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;A1:C1&quot;</span>))\n    sort.<span class=\"hljs-property\">Header</span> = xlYes\n    sort.<span class=\"hljs-property\">MatchCase</span> = <span class=\"hljs-literal\">false</span>\n    sort.<span class=\"hljs-property\">Orientation</span> = xlSortRows\n    sort.<span class=\"hljs-property\">SortMethod</span> = xlPinYin\n    sort.<span class=\"hljs-title class_\">Apply</span>()\n}</code></pre></td></tr></tbody></table></div>",
  "description": "<p>代表数据区域的排序方式。</p>\n",
  "category": "et",
  "properties": [
    {
      "name": "Application",
      "summary": "<p>您可以将此属性与 OLE 自动化对象一起使用以返回该对象的应用程序。</p>\n",
      "description": "<p>如果不与对象识别符一起使用，则此属性返回代表 ET 应用程序的 **<a href=\"./apiObjectTemplate.htm?page=topics/WPS 基础接口/表格 API 参考/Application/Application .htm#Application.Application\">Application</a>**对象。如果与对象识别符一起使用，则此属性返回代表指定对象的创建者的 <strong>Application</strong> 对象。只读。</p>\n",
      "examples": "",
      "type": "Application",
      "readonly": true
    },
    {
      "name": "Creator",
      "summary": "<p>如果该对象是在 ET 中创建的，则此属性返回字符串 XCEL，它等同于十六进制的数字 5843454C。<strong>Creator</strong> 属性是为 Macintosh 上的 ET 设计的，在 Macintosh 上，每个应用程序都具有一个四字符的创建者代码。例如，ET 的创建者代码为 XCEL。</p>\n",
      "description": "<p>返回一个 32 位整数，该整数指示在其中创建此对象的应用程序。只读 <strong>Long</strong> 类型。</p>\n",
      "examples": "",
      "type": "XlCreator",
      "readonly": true
    },
    {
      "name": "Header",
      "summary": "<p>默认值为 <strong>xlNo</strong>。如果希望 ET 确定标题，可以指定 <strong>xlGuess</strong>。</p>\n",
      "description": "<p>指定第一行是否包含标题信息。可读/写 **<a href=\"topics/WPS 基础接口/表格 API 参考/枚举/XlYesNoGuess 枚举.html\">XlYesNoGuess</a>**类型。</p>\n",
      "examples": "<div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*本示例将活动工作表设置为由 ET 确定排序时是否包含标题。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-title class_\">Application</span>.<span class=\"hljs-property\">ActiveSheet</span>.<span class=\"hljs-property\">Sort</span>.<span class=\"hljs-property\">Header</span> = xlGuess\n}</code></pre></td></tr></tbody></table></div><div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*本示例设置第一张工作表排序时第一行包含标题信息。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-title class_\">Application</span>.<span class=\"hljs-property\">Sheets</span>.<span class=\"hljs-title class_\">Item</span>(<span class=\"hljs-number\">1</span>).<span class=\"hljs-property\">Sort</span>.<span class=\"hljs-property\">Header</span> = xlYes\n}</code></pre></td></tr></tbody></table></div>",
      "type": "XlYesNoGuess",
      "readonly": false
    },
    {
      "name": "MatchCase",
      "summary": "",
      "description": "<p>如果设置为 <strong>True</strong>，则执行区分大小写的排序，如果设置为 <strong>False</strong>，则执行不区分大小写的排序。可读/写。</p>\n",
      "examples": "<div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*本示例显示活动工作表排序时是否区分大小写。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-title function_\">alert</span>(<span class=\"hljs-title class_\">Application</span>.<span class=\"hljs-property\">ActiveSheet</span>.<span class=\"hljs-property\">Sort</span>.<span class=\"hljs-property\">MatchCase</span>)\n}</code></pre></td></tr></tbody></table></div><div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*本示例设置第一张工作表排序区分大小写，并通知用户。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-title class_\">Application</span>.<span class=\"hljs-property\">Sheets</span>.<span class=\"hljs-title class_\">Item</span>(<span class=\"hljs-number\">1</span>).<span class=\"hljs-property\">Sort</span>.<span class=\"hljs-property\">MatchCase</span> = <span class=\"hljs-literal\">true</span>\n    <span class=\"hljs-title function_\">alert</span>(<span class=\"hljs-string\">&quot;执行排序区分大小写&quot;</span>)\n}</code></pre></td></tr></tbody></table></div>",
      "type": "boolean",
      "readonly": false
    },
    {
      "name": "Orientation",
      "summary": "<div id=\"vstable\" style=\"font-family:&quot;white-space:normal;\"><table><thead><tr>\n<th>XlSortOrientation 可以是下列 <strong>XlSortOrientation</strong> 常量之一:</th>\n</tr>\n</thead><tbody><tr>\n<td><strong>xlSortColumns</strong></td>\n</tr>\n<tr>\n<td><strong>xlSortRows</strong></td>\n</tr>\n</tbody></table></div>",
      "description": "<p>指定排序方向。可读/写 **<a href=\"topics/WPS 基础接口/表格 API 参考/枚举/XlSortOrientation 枚举.html\">XlSortOrientation</a>**类型。</p>\n",
      "examples": "<div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*本示例设置第一张工作表执行按列排序。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-title class_\">Application</span>.<span class=\"hljs-property\">Sheets</span>.<span class=\"hljs-title class_\">Item</span>(<span class=\"hljs-number\">1</span>).<span class=\"hljs-property\">Sort</span>.<span class=\"hljs-property\">Orientation</span> = xlSortColumns\n}</code></pre></td></tr></tbody></table></div><div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*本示例判断活动工作表执行的排序方向，并通知用户。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-keyword\">if</span> (<span class=\"hljs-title class_\">Application</span>.<span class=\"hljs-property\">ActiveSheet</span>.<span class=\"hljs-property\">Sort</span>.<span class=\"hljs-property\">Orientation</span> == xlSortColumns) {\n        <span class=\"hljs-title function_\">alert</span>(<span class=\"hljs-string\">&quot;排序时执行按列排序&quot;</span>)\n    } <span class=\"hljs-keyword\">else</span> {\n        <span class=\"hljs-title function_\">alert</span>(<span class=\"hljs-string\">&quot;排序时执行按行排序&quot;</span>)\n    }\n}</code></pre></td></tr></tbody></table></div>",
      "type": "XlSortOrientation",
      "readonly": false
    },
    {
      "name": "Parent",
      "summary": "",
      "description": "<p>返回指定对象的父对象。只读。</p>\n",
      "examples": "",
      "type": "Object",
      "readonly": true
    },
    {
      "name": "Rng",
      "summary": "",
      "description": "<p>返回要执行排序的值的区域。只读。</p>\n",
      "examples": "<div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*本示例显示活动工作表排序区域 A1:A5 中的值。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-title class_\">Application</span>.<span class=\"hljs-property\">ActiveSheet</span>.<span class=\"hljs-property\">Sort</span>.<span class=\"hljs-title class_\">SetRange</span>(<span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;A1:A5&quot;</span>))\n    <span class=\"hljs-keyword\">let</span> rng = <span class=\"hljs-title class_\">Application</span>.<span class=\"hljs-property\">ActiveSheet</span>.<span class=\"hljs-property\">Sort</span>.<span class=\"hljs-property\">Rng</span>\n    <span class=\"hljs-title function_\">alert</span>(<span class=\"hljs-string\">`<span class=\"hljs-subst\">${rng.Value2}</span>`</span>)\n}</code></pre></td></tr></tbody></table></div><div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*本示例选中第一张工作表的排序区域。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-title class_\">Application</span>.<span class=\"hljs-property\">Sheets</span>.<span class=\"hljs-title class_\">Item</span>(<span class=\"hljs-number\">1</span>).<span class=\"hljs-property\">Sort</span>.<span class=\"hljs-title class_\">SetRange</span>(<span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;C1:C6&quot;</span>))\n    <span class=\"hljs-title class_\">Application</span>.<span class=\"hljs-property\">Sheets</span>.<span class=\"hljs-title class_\">Item</span>(<span class=\"hljs-number\">1</span>).<span class=\"hljs-property\">Sort</span>.<span class=\"hljs-property\">Rng</span>.<span class=\"hljs-title class_\">Select</span>()\n}</code></pre></td></tr></tbody></table></div>",
      "type": "Range",
      "readonly": true
    },
    {
      "name": "SortFields",
      "summary": "",
      "description": "<p>可用来在工作簿、列表和自动筛选上存储排序状态。只读 **<a href=\"./apiObjectTemplate.htm?page=topics/WPS 基础接口/表格 API 参考/SortFields/SortFields .htm#SortFields.SortFields\">SortFields</a>**类型。</p>\n",
      "examples": "<div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*本示例在活动工作表创建新的排序字段。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-title class_\">Application</span>.<span class=\"hljs-property\">ActiveSheet</span>.<span class=\"hljs-property\">Sort</span>.<span class=\"hljs-property\">SortFields</span>.<span class=\"hljs-title class_\">Add</span>(<span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;B1:B10&quot;</span>))\n}</code></pre></td></tr></tbody></table></div><div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*本示例在第一张工作表添加两个排序字段，并显示排序字段集合的数量。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-keyword\">let</span> sortfields = <span class=\"hljs-title class_\">Application</span>.<span class=\"hljs-property\">Sheets</span>.<span class=\"hljs-title class_\">Item</span>(<span class=\"hljs-number\">1</span>).<span class=\"hljs-property\">Sort</span>.<span class=\"hljs-property\">SortFields</span>\n    sortfields.<span class=\"hljs-title class_\">Add</span>(<span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;A1:A5&quot;</span>))\n    sortfields.<span class=\"hljs-title class_\">Add</span>(<span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;B1:B5&quot;</span>))\n    <span class=\"hljs-title function_\">alert</span>(sortfields.<span class=\"hljs-property\">Count</span>)\n}</code></pre></td></tr></tbody></table></div>",
      "type": "SortFields",
      "readonly": true
    },
    {
      "name": "SortMethod",
      "summary": "<div id=\"vstable\" style=\"font-family:&quot;white-space:normal;\"><table><thead><tr>\n<th>XlSortMethod 可以是以下 <strong>SortMethod</strong> 常量之一:</th>\n</tr>\n</thead><tbody><tr>\n<td><strong>xlStroke</strong></td>\n</tr>\n<tr>\n<td><strong>xlPinYin</strong></td>\n</tr>\n</tbody></table></div>",
      "description": "<p>指定中文排序方法。可读/写 **<a href=\"topics/WPS 基础接口/表格 API 参考/枚举/XlSortMethod 枚举.html\">XlSortMethod</a>**类型。</p>\n",
      "examples": "<div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*本示例设置第一张工作表按字符的汉语拼音顺序排序。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-title class_\">Application</span>.<span class=\"hljs-property\">Sheets</span>.<span class=\"hljs-title class_\">Item</span>(<span class=\"hljs-number\">1</span>).<span class=\"hljs-property\">Sort</span>.<span class=\"hljs-property\">SortMethod</span> = xlPinYin\n}</code></pre></td></tr></tbody></table></div><div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*本示例判断活动工作表排序时执行的排序类型，并通知用户。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-keyword\">if</span> (<span class=\"hljs-title class_\">Application</span>.<span class=\"hljs-property\">ActiveSheet</span>.<span class=\"hljs-property\">Sort</span>.<span class=\"hljs-property\">SortMethod</span> == xlPinYin) {\n        <span class=\"hljs-title function_\">alert</span>(<span class=\"hljs-string\">&quot;执行按字符的汉语拼音顺序排序&quot;</span>)\n    } <span class=\"hljs-keyword\">else</span> <span class=\"hljs-keyword\">if</span> (<span class=\"hljs-title class_\">Application</span>.<span class=\"hljs-property\">ActiveSheet</span>.<span class=\"hljs-property\">Sort</span>.<span class=\"hljs-property\">SortMethod</span> == xlStroke) {\n        <span class=\"hljs-title function_\">alert</span>(<span class=\"hljs-string\">&quot;执行按每个字符的笔划数排序&quot;</span>)\n    }\n}</code></pre></td></tr></tbody></table></div>",
      "type": "XlSortMethod",
      "readonly": false
    }
  ],
  "functions": [
    {
      "name": "Apply",
      "summary": "",
      "description": "<p>根据当前应用的排序状态对区域进行排序。</p>\n",
      "examples": "<div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*此示例对第一张工作表中区域 A1:A5 的数据进行升序排序。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-title class_\">Application</span>.<span class=\"hljs-property\">Sheets</span>.<span class=\"hljs-title class_\">Item</span>(<span class=\"hljs-number\">1</span>).<span class=\"hljs-title class_\">Activate</span>()\n    <span class=\"hljs-keyword\">let</span> sort = <span class=\"hljs-title class_\">Application</span>.<span class=\"hljs-property\">ActiveSheet</span>.<span class=\"hljs-property\">Sort</span>\n    sort.<span class=\"hljs-property\">SortFields</span>.<span class=\"hljs-title class_\">Clear</span>()\n    sort.<span class=\"hljs-property\">SortFields</span>.<span class=\"hljs-title class_\">Add</span>(<span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;A1:A5&quot;</span>))\n    sort.<span class=\"hljs-title class_\">SetRange</span>(<span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;A1:A5&quot;</span>))\n    sort.<span class=\"hljs-title class_\">Apply</span>()\n}</code></pre></td></tr></tbody></table></div><div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*此示例为活动工作表区域 B1:B3 赋值，并对区域 B1:B3 进行笔划数排序。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;B1&quot;</span>).<span class=\"hljs-property\">Value2</span> = <span class=\"hljs-string\">&quot;张三&quot;</span>\n    <span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;B2&quot;</span>).<span class=\"hljs-property\">Value2</span> = <span class=\"hljs-string\">&quot;李四&quot;</span>\n    <span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;B3&quot;</span>).<span class=\"hljs-property\">Value2</span> = <span class=\"hljs-string\">&quot;王五&quot;</span>\n    <span class=\"hljs-keyword\">let</span> sort = <span class=\"hljs-title class_\">Application</span>.<span class=\"hljs-property\">ActiveSheet</span>.<span class=\"hljs-property\">Sort</span>\n    sort.<span class=\"hljs-property\">SortFields</span>.<span class=\"hljs-title class_\">Clear</span>()\n    sort.<span class=\"hljs-property\">SortFields</span>.<span class=\"hljs-title class_\">Add</span>(<span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;B1:B3&quot;</span>))\n    sort.<span class=\"hljs-title class_\">SetRange</span>(<span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;B1:B3&quot;</span>))\n    sort.<span class=\"hljs-property\">SortMethod</span> = xlStroke\n    sort.<span class=\"hljs-title class_\">Apply</span>()\n}</code></pre></td></tr></tbody></table></div>",
      "parameters": [],
