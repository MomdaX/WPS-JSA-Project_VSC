      "readonly": true
    }
  ],
  "functions": [
    {
      "name": "Delete",
      "summary": "",
      "description": "<p>删除对象。</p>\n",
      "examples": "<div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*本示例删除工作表 Sheet1 中第一个图表的第一个图表组的垂直线。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-keyword\">let</span> droplines = <span class=\"hljs-title class_\">Application</span>.<span class=\"hljs-property\">Worksheets</span>.<span class=\"hljs-title class_\">Item</span>(<span class=\"hljs-string\">&quot;Sheet1&quot;</span>).<span class=\"hljs-title class_\">ChartObjects</span>(<span class=\"hljs-number\">1</span>).<span class=\"hljs-property\">Chart</span>.<span class=\"hljs-title class_\">ChartGroups</span>(<span class=\"hljs-number\">1</span>).<span class=\"hljs-property\">DropLines</span>\n    droplines.<span class=\"hljs-title class_\">Delete</span>()\n}</code></pre></td></tr></tbody></table></div><div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*本示例判断如果图表工作表 Chart1 中图表的第一个图表组的垂直线的颜色为红色，则删除该垂直线。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-keyword\">let</span> droplines = <span class=\"hljs-title class_\">Application</span>.<span class=\"hljs-property\">Charts</span>.<span class=\"hljs-title class_\">Item</span>(<span class=\"hljs-string\">&quot;Chart1&quot;</span>).<span class=\"hljs-title class_\">ChartObjects</span>(<span class=\"hljs-number\">1</span>).<span class=\"hljs-property\">Chart</span>.<span class=\"hljs-title class_\">ChartGroups</span>(<span class=\"hljs-number\">1</span>).<span class=\"hljs-property\">DropLines</span>\n    <span class=\"hljs-keyword\">if</span> (droplines.<span class=\"hljs-property\">Border</span>.<span class=\"hljs-property\">ColorIndex</span> == <span class=\"hljs-number\">3</span>) {\n        droplines.<span class=\"hljs-title class_\">Delete</span>()\n    }\n}</code></pre></td></tr></tbody></table></div>",
      "parameters": [],
      "returns": "<p>Variant</p>\n"
    },
    {
      "name": "Select",
      "summary": "",
      "description": "<p>选择对象。</p>\n",
      "examples": "<div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*本示例选中工作表 Sheet1 中第一个图表的第一个图表组的垂直线。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-keyword\">let</span> droplines = <span class=\"hljs-title class_\">Application</span>.<span class=\"hljs-property\">Worksheets</span>.<span class=\"hljs-title class_\">Item</span>(<span class=\"hljs-string\">&quot;Sheet1&quot;</span>).<span class=\"hljs-title class_\">ChartObjects</span>(<span class=\"hljs-number\">1</span>).<span class=\"hljs-property\">Chart</span>.<span class=\"hljs-title class_\">ChartGroups</span>(<span class=\"hljs-number\">1</span>).<span class=\"hljs-property\">DropLines</span>\n    droplines.<span class=\"hljs-title class_\">Select</span>()\n}</code></pre></td></tr></tbody></table></div><div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*本示例判断如果图表工作表 Chart1 中图表的第一个图表组的垂直线的名称为“垂直线 1”，则选中该垂直线。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-keyword\">let</span> droplines = <span class=\"hljs-title class_\">Application</span>.<span class=\"hljs-property\">Charts</span>.<span class=\"hljs-title class_\">Item</span>(<span class=\"hljs-string\">&quot;Chart1&quot;</span>).<span class=\"hljs-title class_\">ChartObjects</span>(<span class=\"hljs-number\">1</span>).<span class=\"hljs-property\">Chart</span>.<span class=\"hljs-title class_\">ChartGroups</span>(<span class=\"hljs-number\">1</span>).<span class=\"hljs-property\">DropLines</span>\n    <span class=\"hljs-keyword\">if</span> (droplines.<span class=\"hljs-property\">Name</span> == <span class=\"hljs-string\">&quot;垂直线 1&quot;</span>) {\n        droplines.<span class=\"hljs-title class_\">Select</span>()\n    }\n}</code></pre></td></tr></tbody></table></div>",
      "parameters": [],
      "returns": "<p>Variant</p>\n"
    }
  ]
