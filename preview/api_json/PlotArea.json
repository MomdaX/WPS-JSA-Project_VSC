      "examples": "<div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*本示例在 Chart1 中的绘图区内绘制带点线的矩形。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-keyword\">let</span> chart = <span class=\"hljs-title class_\">Application</span>.<span class=\"hljs-title class_\">Charts</span>(<span class=\"hljs-string\">&quot;Chart1&quot;</span>).<span class=\"hljs-title class_\">ChartObjects</span>(<span class=\"hljs-number\">1</span>).<span class=\"hljs-property\">Chart</span>\n    <span class=\"hljs-keyword\">let</span> plotArea = chart.<span class=\"hljs-property\">PlotArea</span>\n    <span class=\"hljs-keyword\">let</span> shape = chart.<span class=\"hljs-property\">Shapes</span>.<span class=\"hljs-title class_\">AddShape</span>(msoShapeRectangle, plotArea.<span class=\"hljs-property\">InsideLeft</span>, plotArea.<span class=\"hljs-property\">InsideTop</span>, plotArea.<span class=\"hljs-property\">InsideWidth</span>, plotArea.<span class=\"hljs-property\">InsideHeight</span>)\n    shape.<span class=\"hljs-property\">Fill</span>.<span class=\"hljs-property\">Transparency</span> = <span class=\"hljs-number\">1</span>\n    shape.<span class=\"hljs-property\">Line</span>.<span class=\"hljs-property\">DashStyle</span> = msoLineDashDot\n}</code></pre></td></tr></tbody></table></div><div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*下例将 Sheet1 上第一个图表边界到绘图区内部左边界的距离设置为15磅。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-keyword\">let</span> plotArea = <span class=\"hljs-title class_\">Application</span>