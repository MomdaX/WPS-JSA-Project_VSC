.<span class=\"hljs-property\">Worksheets</span>.<span class=\"hljs-title class_\">Item</span>(<span class=\"hljs-string\">&quot;Sheet1&quot;</span>).<span class=\"hljs-title class_\">ChartObjects</span>(<span class=\"hljs-number\">1</span>).<span class=\"hljs-property\">Chart</span>.<span class=\"hljs-property\">PlotArea</span>\n    plotArea.<span class=\"hljs-property\">InsideTop</span> = <span class=\"hljs-number\">25</span>\n}</code></pre></td></tr></tbody></table></div>",
