      "examples": "<div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*本示例设置活动工作簿上第三个切片器缓存中“id”切片器的宽度。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-keyword\">let</span> slicer = <span class=\"hljs-title class_\">ActiveWorkbook</span>.<span class=\"hljs-title class_\">SlicerCaches</span>(<span class=\"hljs-number\">3</span>).<span class=\"hljs-property\">Slicers</span>.<span class=\"hljs-title class_\">Item</span>(<span class=\"hljs-string\">&quot;id&quot;</span>)\n    slicer.<span class=\"hljs-property\">Width</span> = (<span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;F1&quot;</span>).<span class=\"hljs-property\">Width</span>) * <span class=\"hljs-number\">3</span>\n}</code></pre></td></tr></tbody></table></div><div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*本示例显示活动工作表上第一张数据透视表的第二个切片器的宽度。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-title function_\">alert</span>(<span class=\"hljs-title class_\">ActiveSheet</span>.<span class=\"hljs-title class_\">PivotTables</span>(<span class=\"hljs-number\">1</span>).<span class=\"hljs-property\">Slicers</span>.<span class=\"hljs-title class_\">Item</span>(<span class=\"hljs-number\">2</span>).<span class=\"hljs-property\">Width</span>)\n}</code></pre></td></tr></tbody></table></div>",
      "type": "number（double 精度）",
      "readonly": false
    }
