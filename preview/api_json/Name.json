1!R11C4”（由R1C1-样式引用和用户语言表示）。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-title class_\">ActiveWorkbook</span>.<span class=\"hljs-property\">Names</span>.<span class=\"hljs-title class_\">Item</span>(<span class=\"hljs-number\">2</span>).<span class=\"hljs-property\">RefersToR1C1Local</span> = <span class=\"hljs-string\">&quot;=Sheet1!R11C4&quot;</span>\n}</code></pre></td></tr></tbody></table></div>",
