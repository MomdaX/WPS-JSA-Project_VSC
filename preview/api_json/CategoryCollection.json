ljs-number\">1</span>)\n    <span class=\"hljs-keyword\">if</span> (chartgroup.<span class=\"hljs-title class_\">CategoryCollection</span>().<span class=\"hljs-title class_\">Item</span>(<span class=\"hljs-number\">2</span>).<span class=\"hljs-property\">IsFiltered</span>) {\n        <span class=\"hljs-title function_\">alert</span>(<span class=\"hljs-string\">&quot;筛选出序列&quot;</span>)\n    } <span class=\"hljs-keyword\">else</span> {\n        <span class=\"hljs-title function_\">alert</span>(<span class=\"hljs-string\">&quot;未筛选出序列&quot;</span>)\n    }\n}</code></pre></td></tr></tbody></table></div>",
