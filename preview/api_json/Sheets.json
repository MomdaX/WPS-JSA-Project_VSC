    {
      "name": "PrintOut",
      "summary": "<p><em>From</em> 和 <em>To</em> 所描述的“页”指的是要打印的页，并非指定工作表或工作簿中的全部页。</p>\n",
      "description": "<p>打印对象。返回Variant值</p>\n",
      "examples": "<div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*此示例打印活动工作簿中的所有工作表。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-title class_\">Application</span>.<span class=\"hljs-property\">ActiveWorkbook</span>.<span class=\"hljs-property\">Sheets</span>.<span class=\"hljs-title class_\">PrintOut</span>()\n}</code></pre></td></tr></tbody></table></div><div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*此示例将名为“Sheet1”的工作表从第 2 页打印到第 3 页，打印5份。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-keyword\">let</span> names = [<span class=\"hljs-string\">&quot;Sheet1&quot;</span>]\n    <span class=\"hljs-title class_\">Sheets</span>.<span class=\"hljs-title class_\">Item</span>(names).<span class=\"hljs-title class_\">PrintOut</span>(<span class=\"hljs-number\">2</span>, <span class=\"hljs-number\">3</span>, <span class=\"hljs-number\">5</span>, <span class=\"hljs-literal\">true</span>)\n}</code></pre></td></tr></tbody></table></div>",
      "parameters": [
        {
          "name": "From",
          "type": "any",
          "description": "<p>打印的开始页号。如果省略此参数，则从起始位置开始打印。</p>\n",
          "optional": true
        },
        {
          "name": "To",
          "type": "any",
          "description": "<p>打印的终止页号。如果省略此参数，则打印至最后一页。</p>\n",
          "optional": true
        },
        {
          "name": "Copies",
