  "functions": [
    {
      "name": "Characters",
      "summary": "<p><strong>Characters</strong> 对象不是集合。</p>\n",
      "description": "<p>返回一个 <strong><a href=\"./apiObjectTemplate.htm?page=topics/WPS 基础接口/表格 API 参考/Characters/Characters .htm#Characters.Characters\">Characters</a></strong> 对象，该对象代表当前用户界面中显示的关联 <strong><a href=\"./apiObjectTemplate.htm?page=topics/WPS 基础接口/表格 API 参考/Range/Range .htm#Range.Range\">Range</a></strong> 对象的文本字符区域。只读。</p>\n",
      "examples": "<div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*此示例显示 A3 单元格文本中前两个字符的字体颜色是否为红色。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-title function_\">alert</span>(<span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;A3&quot;</span>).<span class=\"hljs-property\">DisplayFormat</span>.<span class=\"hljs-title class_\">Characters</span>(<span class=\"hljs-number\">1</span>, <span class=\"hljs-number\">2</span>).<span class=\"hljs-property\">Font</span>.<span class=\"hljs-property\">Color</span> == <span class=\"hljs-title function_\">RGB</span>(<span class=\"hljs-number\">255</span>, <span class=\"hljs-number\">0</span>, <span class=\"hljs-number\">0</span>))\n}</code></pre></td></tr></tbody></table></div><div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*此示例显示第一个工作表中 B5 单元格文本的字体大小。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-title function_\">alert</span>(<span class=\"hljs-title class_\">Worksheets</span>.<span class=\"hljs-title class_\">Item</span>(<span class=\"hljs-number\">1</span>).<span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;B5&quot;</span>).<span class=\"hljs-property\">DisplayFormat</span>.<span class=\"hljs-title class_\">Characters</span>().<span class=\"hljs-property\">Font</span>.<span class=\"hljs-property\">Size</span>)\n}</code></pre></td></tr></tbody></table></div>",
      "parameters": [
        {
          "name": "Start",
          "type": "any",
          "description": "<p>要返回的第一个字符。如果此参数是 1 或被省略，则此属性返回一个以第一个字符为开头的字符区域。</p>\n",
          "optional": true
        },
        {
          "name": "Length",
          "type": "any",
          "description": "<p>要返回的字符数。如果省略此参数，则此属性返回字符串的后半部分（<em>Start</em> 字符之后的所有字符）。</p>\n",
          "optional": true
        }
      ],
      "returns": "<p>Characters</p>\n"
    }
  ]
}