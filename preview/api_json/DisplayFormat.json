      "examples": "<div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*本示例显示 D3 单元格用户界面中展示的用户语言的格式代码。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-title function_\">alert</span>(<span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;D3&quot;</span>).<span class=\"hljs-property\">DisplayFormat</span>.<span class=\"hljs-property\">NumberFormatLocal</span>)\n}</code></pre></td></tr></tbody></table></div><div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*本示例显示 D3 单元格用户界面中展示的用户语言的格式代码是否为0.00，并通知用户。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-keyword\">if</span> (<span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;D5:D10&quot;</span>).<span class=\"hljs-property\">DisplayFormat</span>.<span class=\"hljs-property\">NumberFormatLocal</span> == <span class=\"hljs-string\">&quot;0.00&quot;</span>) {\n        <span class=\"hljs-title function_\">alert</span>(<span class=\"hljs-string\">&quot;用户语言的格式代码是0.00&quot;</span>)\n    } <span class=\"hljs-keyword\">else</span> {\n        <span class=\"hljs-title function_\">alert</span>(<span class=\"hljs-string\">&quot;用户语言的格式代码不是0.00&quot;</span>)\n    }\n}</code></pre></td></tr></tbody></table></div>",
