  "functions": [
    {
      "name": "Add",
      "summary": "",
      "description": "<p><span style=\"font-family:&quot;white-space:normal;background-color:#FFFFFF;\">创建一个新的命令栏并将其添加到命令栏集合中。</span> </p>",
      "parameters": [
        {
          "name": "Name",
          "type": "Variant",
          "description": "新命令栏的名称。如果省略此参数，则为命令栏指定默认名称（如 Custom 1）。",
          "default": "",
          "optional": true,
          "nullable": ""
        },
        {
          "name": "Position",
          "type": "Variant",
          "description": "新命令栏的位置或类型。可以是 MsoBarPosition 常量之一。",
          "default": "",
          "optional": true,
          "nullable": ""
        },
        {
          "name": "MenuBar",
          "type": "Variant",
          "description": "设置为 true 将以新命令栏替换活动菜单栏。默认值为 false。",
          "default": "",
          "optional": true,
          "nullable": ""
        },
        {
          "name": "Temporary",
          "type": "Variant",
          "description": "如果为 true，则将使新命令栏变成临时命令栏。临时命令栏将在容器应用程序关闭时删除。默认值为 false。",
          "default": "",
          "optional": true,
          "nullable": ""
        }
      ],
      "examples": "<div id=\"vstable\"><table width=\"100%\"><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>)\n{\n\t<span class=\"hljs-keyword\">let</span> cbar1 = <span class=\"hljs-title class_\">Application</span>.<span class=\"hljs-property\">ActiveDocument</span>.<span class=\"hljs-property\">CommandBars</span>.<span class=\"hljs-title class_\">Add</span>(<span class=\"hljs-string\">&quot;Custom1&quot;</span>, msoBarFloating)\n\tcbar1.<span class=\"hljs-property\">Visible</span> = <span class=\"hljs-literal\">true</span>\n}</code></pre></td></tr></table></div>",
      "returns": ""
    },
