        {
          "name": "Visible",
          "type": "Variant",
          "description": "如果为 true，则只能在搜索中包含可见的命令栏控件。默认值为 false。",
          "default": "",
          "optional": true,
          "nullable": ""
        }
      ],
      "examples": "<div id=\"vstable\"><table width=\"100%\"><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">//本示例用 FindControls 方法返回 CommandBars 集合中所有 ID 为 18 的成员，并在消息框中显示符合指定条件的控件的个数。</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>)\n{\n\t<span class=\"hljs-keyword\">let</span>  myControls = <span class=\"hljs-title class_\">CommandBars</span>.<span class=\"hljs-title class_\">FindControls</span>(msoControlButton,<span class=\"hljs-number\">18</span>)\n\t<span class=\"hljs-title function_\">alert</span>(<span class=\"hljs-string\">&quot;There are &quot;</span> + myControls.<span class=\"hljs-property\">Count</span> + <span class=\"hljs-string\">&quot; controls that meet the search criteria.&quot;</span>)\n}</code></pre></td></tr></table></div>",
