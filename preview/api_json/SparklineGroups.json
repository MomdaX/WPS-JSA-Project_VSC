          "description": "<p>代表要用于创建迷你图的区域。</p>\n",
          "optional": false
        }
      ],
      "returns": "<p>SparklineGroup</p>\n"
    },
    {
      "name": "Clear",
      "summary": "",
      "description": "<p>清除选定的迷你图。</p>\n",
      "examples": "<div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*此示例清除活动工作表上区域 A1:A2 上迷你图组的迷你图。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-keyword\">let</span> sparklineGroups = <span class=\"hljs-title class_\">ActiveSheet</span>.<span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;A1:A2&quot;</span>).<span class=\"hljs-property\">SparklineGroups</span>\n    sparklineGroups.<span class=\"hljs-title class_\">Clear</span>()\n}</code></pre></td></tr></tbody></table></div><div id=\"vstable\"><table width=\"100%\"><tbody><tr><th>示例代码<span class=\"copy\" onclick=\"copyCode(this)\">复制</span></th></tr><tr><td><pre><code><span class=\"hljs-comment\">/*此示例清除第一张工作表上区域 A1:A2 上迷你图组的迷你图，并显示该区域上迷你图组的数量。*/</span>\n<span class=\"hljs-keyword\">function</span> <span class=\"hljs-title function_\">test</span>(<span class=\"hljs-params\"></span>) {\n    <span class=\"hljs-keyword\">let</span> sparklineGroups = <span class=\"hljs-title class_\">Worksheets</span>.<span class=\"hljs-title class_\">Item</span>(<span class=\"hljs-number\">1</span>).<span class=\"hljs-title class_\">Range</span>(<span class=\"hljs-string\">&quot;A1:A2&quot;</span>).<span class=\"hljs-property\">SparklineGroups</span>\n    sparklineGroups.<span class=\"hljs-title class_\">Clear</span>()\n    <span class=\"hljs-title function_\">alert</span>(sparklineGroups.<span class=\"hljs-property\">Count</span>)\n}</code></pre></td></tr></tbody></table></div>",
      "parameters": [],
